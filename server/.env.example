# annesc — downstream site environment configuration
# Copy this file to .env and customize values for your deployment.

# Upstream baizor.com connection
SYNC_UPSTREAM_BASE=https://baizor.com
SITE_DOWNSTREAM_ENABLED=true
SITE_DOWNSTREAM_NAME=annesc
SITE_DOWNSTREAM_UPSTREAM_URL=https://baizor.com

# Node name (unique per instance, used for multi-instance management)
NODE_NAME=annesc-node-1

# Database (see docker-compose.yml for matching settings)
SQL_DSN=sqlite://data/annesc.db

# Redis
REDIS_CONN_STRING=redis://:annesc-redis@redis:6379

# Session
SESSION_SECRET=change-me-to-a-random-string

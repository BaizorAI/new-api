# 本地混合部署统一环境变量
# 用途：同时供 docker-compose.hermes-local.yml 和 New-Api (go run main.go) 使用
# 用法：
#   1. 复制本文件为 .env：Copy-Item .env.hermes-local.example .env
#   2. 启动 Hermes：docker compose -f docker-compose.hermes-local.yml up -d
#   3. 启动 New-Api：go run main.go
#
# 注意：
# - 生产环境请务必修改 HERMES_API_SERVER_KEY 和 SESSION_SECRET
# - docker-compose 默认会读取当前目录的 .env 文件
# - New-Api 启动时也会通过 godotenv 加载 .env 文件

# =============================================================================
# New-Api 基础配置
# =============================================================================
PORT=3000

# 必须设置为 0000，与前端构建产物中的 assetPrefix 一致，否则静态资源会 404
VERSION=0000

# SQLite 本地数据库路径（相对路径会以当前工作目录为基准）
SQLITE_PATH=./data/one-api.db

# 错误日志记录
ERROR_LOG_ENABLED=true

# 批量更新
BATCH_UPDATE_ENABLED=true

# 可选：Redis（如不需要则留空）
# REDIS_CONN_STRING=redis://localhost:6379/0

# 会话密钥（生产环境务必修改）
SESSION_SECRET=local-dev-secret-change-me

# =============================================================================
# Hermes-Agent 配置
# =============================================================================
# Hermes-Agent API Server 地址（Hermes 在 Docker 中，New-Api 在宿主机）
HERMES_API_SERVER_URL=http://localhost:8642

# 当前 Hermes 容器的 API_SERVER_KEY，与 docker-compose.hermes-local.yml 中的默认值一致
# 后台渠道 #2 HermesAgent 的 API 密钥也请填这个值
HERMES_API_SERVER_KEY=7d4a551de0f1148f65d62e9f294e1c35982fe5c3bb9afe0e7be1c8d1f3c6d9fe

# Hermes 监听端口
HERMES_API_SERVER_PORT=8642

# Hermes 容器运行用户/组 ID
HERMES_UID=10000
HERMES_GID=10000

# Hermes 调用 New-Api 进行推理时用的 Key；先留空，待 New-Api 创建令牌后回填并重启 Hermes
HERMES_INFERENCE_API_KEY=

# Hermes 调用 New-Api 的 Base URL
HERMES_INFERENCE_BASE_URL=http://host.docker.internal:3000/v1

# Docker 镜像
HERMES_IMAGE=ccr.ccs.tencentyun.com/lucky/baizor-hermes:1.0.17
